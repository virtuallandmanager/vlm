{
  "name": "vlm-smart-item-dcl",
  "version": "2.0.0",
  "description": "VLM Smart Item for Decentraland — drag into any scene to connect to VLM",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "echo 'vlm-smart-item-dcl: skip in CI, build locally with pnpm run bundle'",
    "bundle": "tsc && node build.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@dcl/sdk": ">=7.7.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@dcl/sdk": ">=7.7.0",
    "@types/node": "^22.0.0",
    "colyseus.js": "^0.15.26",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vlm-adapter-dcl": "workspace:*",
    "vlm-client": "workspace:*",
    "vlm-core": "workspace:*",
    "vlm-hud": "workspace:*",
    "vlm-shared": "workspace:*"
  },
  "files": [
    "dist",
    "asset.json",
    "models",
    "README.md"
  ]
}
