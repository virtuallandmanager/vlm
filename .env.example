# =============================================================================
# VLM V2 — Environment Variables
# =============================================================================
# Copy to .env and edit. Only REQUIRED vars need values to start.
#
# Modes:
#   single   — One server, in-memory presence, all features free (default)
#   scalable — Multiple servers + Redis, all features free
#   cloud    — Multi-tenant SaaS with billing + feature gating

# =============================================================================
# REQUIRED (all modes)
# =============================================================================
VLM_MODE=single
DATABASE_URL=postgresql://vlm:vlm_dev@localhost:5432/vlm
JWT_SECRET=change-me-to-a-random-64-char-string
PUBLIC_URL=http://localhost:3010

# =============================================================================
# STORAGE
# =============================================================================
# Provider: local (default) | supabase | s3 | r2
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# Supabase (single mode external storage):
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# S3 / R2:
# S3_BUCKET=vlm-media
# S3_REGION=auto                         # Use "auto" for R2
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com  # For R2 or MinIO (omit for AWS S3)
# AWS_ACCESS_KEY_ID=                     # R2 or S3 access key
# AWS_SECRET_ACCESS_KEY=                 # R2 or S3 secret key
# CDN_URL=https://cdn.vlm.gg             # Custom domain for public file URLs (optional)

# =============================================================================
# SCALABLE / CLOUD MODE
# =============================================================================
# REDIS_URL=redis://localhost:6379       # Required for scalable/cloud

# =============================================================================
# BILLING (cloud mode only — omit = all features free)
# =============================================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# =============================================================================
# OPTIONAL — Features
# =============================================================================
# ENABLE_STREAMING=false                 # HLS streaming (requires FFmpeg)
# ENABLE_METRICS=false                   # Prometheus /metrics endpoint
# MULTI_TENANT=false                     # Data isolation between orgs
# CORS_ORIGINS=                          # Additional allowed origins (comma-separated, used in production)

# =============================================================================
# OPTIONAL — Auth providers (omit to disable)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OAUTH_CALLBACK_URL=                   # Base URL for OAuth callbacks (defaults to PUBLIC_URL)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# ALCHEMY_API_KEY=
# API keys are managed via /api/keys endpoints (no env config needed)

# =============================================================================
# OPTIONAL — Tuning
# =============================================================================
PORT=3010
# LOG_LEVEL=info                         # debug | info | warn | error
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d
# MAX_ROOMS=50                           # Max concurrent Colyseus rooms per server
# RATE_LIMIT_MAX=100                     # Max requests per minute per IP (global)
# MAX_UPLOAD_MB=100                      # Max upload body size in MB (default 100)
# DB_POOL_MAX=10                         # Max database connections in pool
# DASHBOARD_DIR=./dashboard              # Path to static dashboard files

# =============================================================================
# Docker Compose helpers (used by compose files, not by the app directly)
# =============================================================================
# POSTGRES_PASSWORD=vlm_prod
