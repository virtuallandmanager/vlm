{
  "name": "vlm-server",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@colyseus/redis-driver": "^0.17.6",
    "@colyseus/redis-presence": "^0.15.6",
    "@colyseus/ws-transport": "^0.15.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "colyseus": "^0.15.26",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "google-auth-library": "^10.6.2",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "stripe": "^17.0.0",
    "vlm-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
